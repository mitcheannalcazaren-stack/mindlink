'use client'

import { useState } from 'react'
import { motion } from 'framer-motion'
import { 
  Brain, 
  Users, 
  Calendar, 
  BarChart3, 
  MessageSquare, 
  FileText,
  Clock,
  User,
  Star,
  AlertTriangle,
  TrendingUp,
  Heart,
  Shield,
  Video,
  Phone,
  Activity,
  Target,
  CheckCircle,
  Eye,
  Edit,
  Download,
  X
} from 'lucide-react'
import { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, PieChart, Pie, Cell, BarChart, Bar } from 'recharts'

interface Client {
  id: string
  name: string
  age: number
  email: string
  phone: string
  riskLevel: 'Mild' | 'Moderate' | 'Severe'
  lastSession: string
  nextSession: string
  progress: number
  aiInsights: string[]
  screeningScore: number
  chatbotInteractions: number
  treatmentJourney: {
    startDate: string
    currentPhase: string
    milestones: string[]
    nextMilestone: string
  }
  image: string
}

interface Session {
  id: string
  clientName: string
  date: string
  time: string
  type: 'virtual' | 'in-person'
  status: 'upcoming' | 'completed' | 'in-progress'
  duration: number
  notes?: string
}

interface AIReport {
  id: string
  clientId: string
  clientName: string
  screeningResults: {
    score: number
    riskLevel: string
    date: string
  }
  chatbotAnalysis: {
    sentiment: 'Positive' | 'Neutral' | 'Negative'
    topics: string[]
    frequency: number
    lastInteraction: string
  }
  recommendations: string[]
  generatedDate: string
}

